  "dataset": {
    "name": "Population by sex, 5-year age groups and nationality since 2002 - districts of Vienna",

    "source": "Statistik Austria",

    "license": "CC BY 4.0",

    "temporalCoverage": "2002-2025",

    "spatialCoverage": "Vienna, Austria"
  },

  "databaseSchema": {
    "schemaType": "Normalized relational schema (3NF)",

    "mainTables": [
      "Population_statistics",
      "District",
      "Time_dimension",
      "Sex",
      "Age_group",
      "Nationality_group"
    ]
  },

  "sqlViews": [
    "population_by_district",
    "population_by_nationality",
    "population_pyramid_base"
  ],

  "workflowSteps": [
    "data preprocessing",
    "feature engineering",
    "SQL analytical views",
    "DBRepo API retrieval",
    "machine learning preparation",
    "forecasting workflow preparation"
  ],

  "machineLearningModels": [
    "Random Forest",
    "Linear Regression"
  ],

  "apiIntegration": {
    "platform": "DBRepo",

    "baseURL": "https://test.dbrepo.tuwien.ac.at/api",

    "datasetID": "38707917-e942-45c3-a3dd-d2bfc1c106af"
  },

